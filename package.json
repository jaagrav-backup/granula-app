{
  "name": "granula-app",
  "version": "1.0.1",
  "description": "Granula — AI meeting notes for wealth advisors",
  "main": "main.js",
  "author": "Jaagrav Seal <contact@jaagrav.in>",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "build:renderer": "vite build",
    "build": "vite build && electron-builder --mac --dir",
    "build:dmg": "vite build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "notetaker": "file:../notetaker-sdk",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3"
  },
  "build": {
    "appId": "com.jaagrav.Granula",
    "productName": "Granula",
    "files": [
      "main.js",
      "preload.js",
      "dist-renderer/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.inherit.plist",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Granula needs microphone access to record your voice during meetings.",
        "NSScreenCaptureUsageDescription": "Granula needs screen recording permission to capture system audio from your desktop.",
        "NSAudioCaptureUsageDescription": "Granula uses Apple's CoreAudio Tap API to capture system audio. This permission is required on macOS 14.2 and later."
      }
    }
  }
}
